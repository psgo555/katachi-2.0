@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <!-- 商品詳細頁設定 -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KATACHI PRODUCT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Noto+Sans+JP:wght@100;200;300;500;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true">
  <link rel="stylesheet" href="~/katachi-shop/css/product-detail.css" asp-append-version="true">
</head>

<body>
  <div class="detail-shell">
    <!-- 頂部導覽 -->
    <header class="detail-topbar">
      <a class="brand" asp-controller="Home" asp-action="Index">
        KATACH
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
            <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
            <rect x="11" y="20" width="6" height="40" fill="currentColor" />
            <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
            <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
          </svg>
        </span>
        SHOP
      </a>

      <div class="detail-topbar__actions">
        <a class="ghost-btn" asp-controller="Shop" asp-action="Index">返回商店</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
          <a class="user-chip" asp-controller="Account" asp-action="Logout" title="登出" aria-label="登出">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="9" cy="6" r="3.25" stroke="currentColor" stroke-width="2" />
              <path d="M1.5 17c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </a>
          <a class="order-link" asp-controller="Shop" asp-action="MyOrders">我的訂單</a>
        }
        else
        {
          <a class="user-chip" asp-controller="Account" asp-action="Index" title="會員登入" aria-label="會員登入">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <circle cx="9" cy="6" r="3.25" stroke="currentColor" stroke-width="2" />
              <path d="M1.5 17c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </a>
        }
        <button class="cart-chip" id="detailCartBtn" type="button" aria-label="查看購物車">
          <i class="fa fa-shopping-cart" aria-hidden="true"></i>
          <span id="detailCartCount">0</span>
        </button>
      </div>
    </header>

    <main class="detail-page">
      <nav class="breadcrumb">
        <a asp-controller="Shop" asp-action="Index">商店首頁</a>
        <span>/</span>
        <span id="detailCategoryLabel">商品分類</span>
        <span>/</span>
        <span id="detailNameTrail">商品名稱</span>
      </nav>

      <!-- 商品主要資訊 -->
      <section class="detail-grid">
        <div class="detail-visual-wrap">
          <div class="detail-visual">
            <img id="detailImage" src="" alt="">
          </div>
          <!-- 口味縮圖列，由 JS 動態生成 -->
          <div class="detail-thumbs" id="detailThumbs"></div>
        </div>

        <div class="detail-info">
          <div class="detail-kicker" id="detailCategoryKicker">商品分類</div>
          <h1 class="detail-title" id="detailName">商品名稱</h1>
          <div class="detail-rating" id="detailRating"></div>
          <p class="detail-copy" id="detailDescription">商品說明</p>

          <div class="detail-price">
            <strong id="detailPrice">0</strong>
            <span id="detailOriginalPrice">0</span>
          </div>

          <div class="detail-highlights" id="detailHighlights"></div>

          <!-- 商品規格 / 分類選擇 -->
          <div class="detail-options" id="detailOptions"></div>

          <div class="detail-qty">
            <span>數量</span>
            <div class="qty-picker">
              <button class="qty-btn" id="qtyDecrease" type="button">−</button>
              <span class="qty-value" id="qtyValue">1</span>
              <button class="qty-btn" id="qtyIncrease" type="button">+</button>
            </div>
          </div>

          <div class="detail-summary" id="detailSummary">已選擇：--</div>

          <div class="detail-actions">
            <button class="accent-btn" id="detailAddCart" type="button">加入購物車</button>
            <button class="ghost-btn" id="detailBuyNow" type="button">立即購買</button>
          </div>
        </div>
      </section>

      <section class="product-info-section" id="productInfoSection" hidden>
        <div class="product-info-head">
          <div class="detail-kicker">Product Specs</div>
          <h2>商品介紹</h2>
        </div>
        <div class="product-info-grid" id="productInfoGrid"></div>
      </section>
    </main>
  </div>

  <!-- 購物車遮罩與右側抽屜 -->
  <div class="cart-overlay" id="cartOverlay" aria-hidden="true">
    <aside class="summary-card" aria-label="購物車與結帳摘要">
      <button class="cart-close" id="cartClose" type="button" aria-label="關閉購物車">✕</button>
      <div class="summary-head">
        <div>
          <div class="summary-kicker">Current Cart</div>
          <h3>今日結帳摘要</h3>
        </div>
        <strong id="cartItemsLabel">0 Items</strong>
      </div>
      <div class="summary-list" id="summaryList"></div>
      <div class="summary-row"><span>商品金額</span><strong id="subtotalValue">0</strong></div>
      <div class="summary-row"><span>宅配運費</span><strong id="shippingValue">0</strong></div>
      <div class="summary-row"><span>會員折扣</span><strong id="discountValue">0</strong></div>
      <div class="summary-row"><span>應付總額</span><strong id="totalValue">0</strong></div>
      <div class="cart-actions">
        <button class="accent-btn" id="checkoutBtn" type="button">前往結帳</button>
        <button class="clear-cart-btn" id="clearCartBtn" type="button">刪除購物車內所有商品</button>
      </div>
      <div class="status-box">今日 16:00 前下單可安排明日出貨。補給品會優先依口味與批號出貨。</div>
    </aside>
  </div>

  <!-- footer區域 -->
  <footer class="site-footer">
    <div class="footer-main">

      <!-- 左:品牌區 -->
      <div class="footer-brand">
        <div class="brand">
          KATACH
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
              <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
              <rect x="11" y="20" width="6" height="40" fill="currentColor" />
              <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
              <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
            </svg>
          </span>
          SHOP
        </div>
        <p>專為訓練者設計的補給品平台，提供高蛋白、肌酸、魚油與日常營養品，讓你專注在每一次的訓練!</p>
      </div>

      <!-- 中:快速連結 -->
      <div class="footer-col">
        <h4>商品分類</h4>
        <ul>
         <li><a asp-controller="Shop" asp-action="Index" asp-route-category="protein">高蛋白</a></li>
         <li><a asp-controller="Shop" asp-action="Index" asp-route-category="performance">訓練補給</a></li>
         <li><a asp-controller="Shop" asp-action="Index" asp-route-category="wellness">日常營養</a></li>
         <li><a asp-controller="Shop" asp-action="Index" asp-route-category="accessories">沖泡配件</a></li>

        </ul>
      </div>

      <!-- 右:服務資訊 -->
      <div class="footer-col">
        <h4>服務資訊</h4>
        <ul>
          <li><a href="#">常見問題</a></li>
          <li><a href="#">配送說明</a></li>
          <li><a href="#">退換貨政策</a></li>
          <li><a asp-controller="Account" asp-action="Index">會員登入</a></li>
        </ul>
      </div>

      <!-- 右:聯絡資訊 -->
      <div class="footer-col">
        <h4>聯絡我們</h4>
        <ul>
          <li>service@katachi.tw</li>
          <li>週一至週五 10:00–18:00</li>
        </ul>
      </div>

    </div>

    <!-- 底部版權列 -->
    <div class="footer-bottom">
      <span>© 2024 KATACHI SHOP. All rights reserved.</span>
      <div class="footer-links">
        <a href="#">隱私權政策</a>
        <a href="#">服務條款</a>
      </div>
    </div>
  </footer>

  <script src="~/katachi-shop/js/product-data.js" asp-append-version="true"></script>
  <script src="~/katachi-shop/js/product-detail.js" asp-append-version="true"></script>
</body>

</html>




