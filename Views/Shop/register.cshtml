@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>建立帳號 | KATACHI SHOP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Noto+Sans+JP:wght@100;200;300;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true">
  <link rel="stylesheet" href="~/katachi-shop/css/login.css" asp-append-version="true">
  
</head>

<body>
  <header class="auth-shop-nav">
    <a class="auth-shop-brand" asp-controller="Home" asp-action="Index">
      KATACH
      <span class="auth-brand-mark" aria-hidden="true">
        <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
          <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
          <rect x="11" y="20" width="6" height="40" fill="currentColor" />
          <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
          <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
        </svg>
      </span>
      SHOP
    </a>
    <nav class="auth-shop-actions" aria-label="會員導覽">
      <a class="auth-nav-link" asp-controller="Shop" asp-action="Index">商店</a>
      <a class="auth-nav-link is-active" asp-controller="Account" asp-action="Index" asp-route-tab="register">會員</a>
    </nav>
  </header>

  <div class="login-shell">
    <!-- 左側視覺區 -->
    <section class="login-visual">
      <div class="visual-top-spacer" aria-hidden="true"></div>

      <div class="visual-copy">
        <div class="eyebrow">Join KATACHI</div>
        <h1 class="visual-title">BUILD<br>YOUR<br>ACCOUNT.</h1>
      </div>

      <div class="visual-links">
        <a class="visual-link" asp-controller="Shop" asp-action="Index">返回商店</a>
        <a class="visual-link" asp-controller="Account" asp-action="Index">已有帳號？登入</a>
      </div>
    </section>

    <!-- 右側表單區 -->
    <section class="login-panel">
      <div class="login-form-wrap">
        <div class="panel-kicker">NEW MEMBER</div>
        <h2 class="panel-title">建立帳號</h2>

        <!-- 成功訊息 -->
        <div class="success-banner" id="successBanner">
          <i class="fa fa-check-circle"></i> 帳號建立成功！正在跳轉至登入頁…
        </div>

        <!-- 錯誤訊息 -->
        <div class="auth-error" id="registerError" style="display:none;background:var(--color-danger-bg);border:1px solid var(--color-danger-line);color:var(--color-danger-text);padding:12px 16px;border-radius:4px;font-size:0.85rem;margin-bottom:16px;">
          <i class="fa fa-exclamation-circle"></i> <span id="registerErrorMsg"></span>
        </div>

        <form class="login-form" id="registerForm" novalidate>

          <!-- 姓名 -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="field-group">
              <label class="field-label" for="reg-lastname">姓氏</label>
              <input class="field-input" id="reg-lastname" type="text" placeholder="王" autocomplete="family-name">
            </div>
            <div class="field-group">
              <label class="field-label" for="reg-firstname">名字</label>
              <input class="field-input" id="reg-firstname" type="text" placeholder="小明" autocomplete="given-name">
            </div>
          </div>

          <!-- Email -->
          <div class="field-group">
            <label class="field-label" for="reg-email">電子郵件</label>
            <input class="field-input" id="reg-email" type="email" placeholder="name@example.com" autocomplete="email">
          </div>

          <!-- 密碼 -->
          <div class="field-group">
            <label class="field-label" for="reg-password">密碼</label>
            <div style="position:relative;">
              <input class="field-input" id="reg-password" type="password" placeholder="至少 8 個字元" autocomplete="new-password" style="padding-right:44px;">
              <button type="button" id="toggleRegPw" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--color-grey-mid);font-size:1rem;padding:0;" aria-label="顯示密碼">
                <i class="fa fa-eye"></i>
              </button>
            </div>
            <div class="strength-bar"><div class="strength-bar__fill" id="strengthFill"></div></div>
            <div class="strength-hint" id="strengthHint"></div>
          </div>

          <!-- 確認密碼 -->
          <div class="field-group">
            <label class="field-label" for="reg-confirm">確認密碼</label>
            <div style="position:relative;">
              <input class="field-input" id="reg-confirm" type="password" placeholder="再輸入一次密碼" autocomplete="new-password" style="padding-right:44px;">
              <button type="button" id="toggleConfirmPw" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--color-grey-mid);font-size:1rem;padding:0;" aria-label="顯示確認密碼">
                <i class="fa fa-eye"></i>
              </button>
            </div>
          </div>

          <!-- 條款 -->
          <div style="display:flex;align-items:flex-start;gap:10px;margin-top:4px;">
            <input type="checkbox" id="reg-terms" style="margin-top:3px;accent-color:var(--color-accent);cursor:pointer;flex-shrink:0;">
            <label for="reg-terms" style="font-size:0.85rem;color:var(--color-grey);line-height:1.6;cursor:pointer;">
              我已閱讀並同意 <a href="#" style="color:var(--color-black);text-decoration:underline;text-underline-offset:2px;">服務條款</a> 與 <a href="#" style="color:var(--color-black);text-decoration:underline;text-underline-offset:2px;">隱私權政策</a>
            </label>
          </div>

          <!-- 送出 -->
          <button class="primary-btn" type="submit" id="registerBtn" style="margin-top:8px;">
            建立帳號 <i class="fa fa-arrow-right" style="margin-left:8px;"></i>
          </button>

        </form>

        <div class="foot-row">
          <span>已有帳號？</span>
          <a class="text-link" asp-controller="Account" asp-action="Index">立即登入</a>
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer style="background:var(--color-black);color:var(--color-white-mute);font-family:var(--font-sans);font-weight:var(--weight-light);">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 80px;border-top:1px solid rgba(255,255,255,0.2);font-size:0.85rem;">
      <span>© 2024 KATACHI SHOP. All rights reserved.</span>
      <div style="display:flex;gap:24px;">
        <a href="#" style="color:rgba(255,255,255,0.6);text-decoration:none;">隱私權政策</a>
        <a href="#" style="color:rgba(255,255,255,0.6);text-decoration:none;">服務條款</a>
      </div>
    </div>
  </footer>

  <script>
    // 顯示/隱藏密碼
    function bindToggle(btnId, inputId) {
      const btn   = document.getElementById(btnId);
      const input = document.getElementById(inputId);
      btn?.addEventListener('click', () => {
        const hidden = input.type === 'password';
        input.type = hidden ? 'text' : 'password';
        btn.querySelector('i').className = hidden ? 'fa fa-eye-slash' : 'fa fa-eye';
      });
    }
    bindToggle('toggleRegPw', 'reg-password');
    bindToggle('toggleConfirmPw', 'reg-confirm');

    // 密碼強度
    document.getElementById('reg-password').addEventListener('input', function () {
      const val = this.value;
      const fill = document.getElementById('strengthFill');
      const hint = document.getElementById('strengthHint');
      let score = 0;
      if (val.length >= 8)  score++;
      if (/[A-Z]/.test(val)) score++;
      if (/[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;

      const levels = [
        { pct: '0%',   color: 'transparent', text: '' },
        { pct: '30%',  color: '#e57373',     text: '密碼強度：弱' },
        { pct: '60%',  color: '#ffb74d',     text: '密碼強度：普通' },
        { pct: '80%',  color: '#81c784',     text: '密碼強度：強' },
        { pct: '100%', color: '#43a047',     text: '密碼強度：非常強' },
      ];
      fill.style.width      = levels[score].pct;
      fill.style.background = levels[score].color;
      hint.textContent      = levels[score].text;
    });

    // 移除 error 狀態
    ['reg-email', 'reg-password', 'reg-confirm', 'reg-lastname', 'reg-firstname'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', function () {
        this.classList.remove('field-error');
        document.getElementById('registerError').style.display = 'none';
      });
    });

    function showError(msg) {
      const el = document.getElementById('registerError');
      document.getElementById('registerErrorMsg').textContent = msg;
      el.style.display = 'block';
    }

    // 表單送出
    document.getElementById('registerForm').addEventListener('submit', (e) => {
      e.preventDefault();
      const lastName  = document.getElementById('reg-lastname').value.trim();
      const firstName = document.getElementById('reg-firstname').value.trim();
      const email     = document.getElementById('reg-email').value.trim();
      const password  = document.getElementById('reg-password').value;
      const confirm   = document.getElementById('reg-confirm').value;
      const terms     = document.getElementById('reg-terms').checked;

      if (!lastName || !firstName) {
        if (!lastName) document.getElementById('reg-lastname').classList.add('field-error');
        if (!firstName) document.getElementById('reg-firstname').classList.add('field-error');
        showError('請填寫姓名。');
        return;
      }
      if (!email || !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
        document.getElementById('reg-email').classList.add('field-error');
        showError('請輸入有效的電子郵件格式。');
        return;
      }
      if (password.length < 8) {
        document.getElementById('reg-password').classList.add('field-error');
        showError('密碼至少需要 8 個字元。');
        return;
      }
      if (password !== confirm) {
        document.getElementById('reg-confirm').classList.add('field-error');
        showError('兩次輸入的密碼不一致。');
        return;
      }
      if (!terms) {
        showError('請先同意服務條款與隱私權政策。');
        return;
      }

      // Demo：顯示成功訊息後跳轉至登入
      document.getElementById('registerBtn').disabled = true;
      document.getElementById('successBanner').classList.add('is-visible');
      sessionStorage.setItem('katachi-register-email', email);
      setTimeout(() => { window.location.href = '/Account/Index'; }, 1800);
    });
  </script>

</body>
</html>



