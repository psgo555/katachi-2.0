@model List<katachi.Models.Shop.Order>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的訂單 | KATACHI SHOP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Noto+Sans+JP:wght@100;200;300;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true">
    <style>
        body {
            margin: 0;
            background: var(--color-off-white);
            color: var(--color-black);
            font-family: "Noto Sans JP", sans-serif;
        }

        .orders-topbar {
            position: sticky;
            top: 0;
            z-index: var(--z-nav, 1000);
            height: 72px;
            padding: 0 6vw;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: var(--color-black);
            color: var(--color-white);
        }

        .brand {
            color: inherit;
            text-decoration: none;
            font-family: "Big Shoulders Display", sans-serif;
            font-size: 2rem;
            font-weight: 800;
            letter-spacing: 0.06em;
        }

        .orders-actions {
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .ghost-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: var(--space-8);
            min-height: 46px;
            padding: 0 var(--space-20);
            border-radius: 8px;
            border: 1px solid var(--color-white);
            background: var(--color-white);
            color: var(--color-black);
            font-family: var(--font-sans);
            font-size: var(--text-sub);
            font-weight: 700;
            text-decoration: none;
            white-space: nowrap;
            transition:
                background var(--dur-instant) var(--ease-out),
                border-color var(--dur-instant) var(--ease-out),
                color var(--dur-instant) var(--ease-out),
                transform var(--dur-instant) var(--ease-out);
        }

        .ghost-btn:hover {
            background: var(--color-accent);
            border-color: var(--color-accent);
            color: var(--color-black);
            transform: translateY(-1px);
        }

        .orders-page {
            width: min(1120px, calc(100% - 40px));
            margin: 56px auto 80px;
        }

        .orders-kicker {
            color: var(--color-grey-mid);
            text-transform: uppercase;
            letter-spacing: .18em;
            font-size: .78rem;
            margin-bottom: 8px;
        }

        .orders-title {
            font-size: clamp(2rem, 4vw, 4rem);
            margin: 0 0 28px;
            font-weight: 800;
        }

        .empty-state,
        .order-card {
            background: var(--color-white);
            border: 1px solid var(--color-border);
            border-radius: 8px;
        }

        .empty-state {
            padding: 32px;
            color: var(--color-grey-mid);
        }

        .order-list {
            display: grid;
            gap: 18px;
        }

        .order-card__head {
            display: grid;
            grid-template-columns: 1.2fr .8fr .7fr .7fr;
            gap: 16px;
            padding: 20px 24px;
            border-bottom: 1px solid var(--color-border);
            align-items: center;
        }

        .order-number {
            font-family: "Big Shoulders Display", sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: .06em;
        }

        .order-meta {
            color: var(--color-grey-mid);
            font-size: .9rem;
        }

        .status-badge {
            display: inline-flex;
            width: fit-content;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(246, 181, 56, .18);
            color: var(--color-black);
            font-weight: 700;
        }

        .status-badge.is-cancelled {
            background: rgba(239, 111, 130, .18);
            color: #b84b5f;
        }

        .status-badge.is-completed {
            background: rgba(64, 154, 100, .18);
            color: #2f7d4f;
        }

        .order-total {
            text-align: right;
            font-family: "Big Shoulders Display", sans-serif;
            font-size: 2rem;
            font-weight: 800;
        }

        .order-items {
            padding: 4px 24px 18px;
        }

        .order-item {
            display: grid;
            grid-template-columns: 64px 1fr auto;
            gap: 16px;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid var(--color-border);
        }

        .order-item:last-child {
            border-bottom: 0;
        }

        .order-item img {
            width: 64px;
            height: 64px;
            object-fit: cover;
            border-radius: 6px;
            background: var(--color-off-white);
        }

        .item-name {
            font-weight: 700;
        }

        .item-sub {
            color: var(--color-grey-mid);
            font-size: .9rem;
            margin-top: 4px;
        }

        @@media (max-width: 760px) {
            .orders-topbar,
            .order-card__head,
            .order-item {
                grid-template-columns: 1fr;
            }

            .orders-topbar {
                height: auto;
                padding-block: 18px;
                align-items: flex-start;
                gap: 14px;
                flex-direction: column;
            }

            .order-total {
                text-align: left;
            }
        }
    </style>
</head>
<body>
    <header class="orders-topbar">
        <a class="brand" asp-controller="Home" asp-action="Index">KATACHI SHOP</a>
        <div class="orders-actions">
            <a class="ghost-btn" asp-controller="Shop" asp-action="Index">返回商店</a>
        </div>
    </header>

    <main class="orders-page">
        <div class="orders-kicker">Member Orders</div>
        <h1 class="orders-title">我的訂單</h1>

        @if (!Model.Any())
        {
            <div class="empty-state">目前沒有查到你的商城訂單。</div>
        }
        else
        {
            <div class="order-list">
                @foreach (var order in Model)
                {
                    var statusClass = order.Status switch
                    {
                        "已取消" => "is-cancelled",
                        "已完成" => "is-completed",
                        _ => ""
                    };

                    <article class="order-card">
                        <div class="order-card__head">
                            <div>
                                <div class="order-meta">訂單編號</div>
                                <div class="order-number">@order.OrderNumber</div>
                            </div>
                            <div>
                                <div class="order-meta">成立時間</div>
                                <div>@order.CreatedAt.ToString("yyyy/MM/dd HH:mm")</div>
                            </div>
                            <span class="status-badge @statusClass">@order.Status</span>
                            <div class="order-total">NT$ @order.Total.ToString("N0")</div>
                        </div>

                        <div class="order-items">
                            @foreach (var item in order.Items)
                            {
                                <div class="order-item">
                                    <img src="@item.ImageUrl" alt="@item.ProductName">
                                    <div>
                                        <div class="item-name">@item.ProductName × @item.Quantity</div>
                                        <div class="item-sub">@item.OptionText</div>
                                    </div>
                                    <strong>NT$ @item.Subtotal.ToString("N0")</strong>
                                </div>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </main>
</body>
</html>

