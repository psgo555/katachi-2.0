@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <!-- 基本頁面設定與字型、樣式載入 -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KATACHI SHOP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Noto+Sans+JP:wght@100;200;300;500;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true">
  <link rel="stylesheet" href="~/katachi-shop/css/shop.css" asp-append-version="true">

</head>

<body>
  <div class="shop-shell">
    <div class="topbar-shell">
      <!-- 頁首：品牌、搜尋、會員、購物車 -->
      <header class="topbar">
        <a class="brand" asp-controller="Home" asp-action="Index">
          KATACH
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
              <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
              <rect x="11" y="20" width="6" height="40" fill="currentColor" />
              <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
              <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
            </svg>
          </span>
          SHOP
        </a>

        <!-- 右上操作區：搜尋、登入、購物車 -->
        <div class="topbar-tools">
            <label class="search-wrap" aria-label="搜尋商品">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"></circle>
                    <path d="M20 20L17 17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
                </svg>
                <input id="searchInput" type="search" placeholder="搜尋高蛋白、肌酸、魚油">
            </label>
            <a class="user-chip" asp-controller="Shop" asp-action="MyOrders" title="我的訂單" aria-label="我的訂單">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="9" cy="6" r="3.25" stroke="currentColor" stroke-width="2" />
                    <path d="M1.5 17c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </a>

            <button class="cart-chip" id="cartToggle" type="button" aria-expanded="false" aria-controls="cartOverlay">
                <!-- 購物車icon -->
                <i class="fa fa-shopping-cart" aria-hidden="true"></i>
                <span id="cartCount">3</span>
            </button>
        </div>
      </header>
    </div>

    <!-- 主要購物介面 -->
    <main class="page-grid">
      <section class="catalog">
        <!-- 上方輪播圖 -->
        <section class="hero-slider" id="heroSlider" aria-label="精選補給輪播">
          <!-- 每一張 article 就是一個輪播頁面 -->
          <article class="hero-slide is-active"
            style="background-image: linear-gradient(180deg, rgba(19, 21, 28, 0.18), rgba(19, 21, 28, 0.72)), url('https://images.unsplash.com/photo-1593095948071-474c5cc2989d?auto=format&fit=crop&w=1600&q=80');">
            <div class="hero-slide__content">
              <div class="eyebrow">Protein Focus</div>
              <h2>WHEY.<br>RECOVER FAST.</h2>
              <p>訓練後先補足蛋白質，讓使用者一進商店就能先看到高蛋白主力商品與入門組合。</p>
              <a class="accent-btn" href="#productGrid">看高蛋白商品</a>
            </div>
          </article>

          <article class="hero-slide"
            style="background-image: linear-gradient(180deg, rgba(19, 21, 28, 0.18), rgba(19, 21, 28, 0.72)), url('https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=1600&q=80');">
            <div class="hero-slide__content">
              <div class="eyebrow">Performance Stack</div>
              <h2>CREATINE.<br>TRAIN HARDER.</h2>
              <p>把肌酸、訓練前補給和 BCAA 放進同一組視覺，讓訓練補給區更直覺。</p>
              <a class="accent-btn" href="#productGrid">看訓練補給</a>
            </div>
          </article>

          <article class="hero-slide"
            style="background-image: linear-gradient(180deg, rgba(19, 21, 28, 0.18), rgba(19, 21, 28, 0.72)), url('https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?auto=format&fit=crop&w=1600&q=80');">
            <div class="hero-slide__content">
              <div class="eyebrow">Daily Wellness</div>
              <h2>OMEGA.<br>DAILY CARE.</h2>
              <p>魚油、綜合維他命和日常營養放在上方輪播，可以把商店主題帶得更完整。</p>
              <a class="accent-btn" href="#productGrid">看日常營養</a>
            </div>
          </article>

          <!-- 輪播切換箭頭 -->
          <button class="hero-slider__nav hero-slider__nav--prev" id="heroPrev" type="button"
            aria-label="上一張">‹</button>
          <button class="hero-slider__nav hero-slider__nav--next" id="heroNext" type="button"
            aria-label="下一張">›</button>

          <!-- 輪播分頁圓點 -->
          <div class="hero-slider__dots" id="heroDots" aria-label="輪播分頁">
            <button class="hero-slider__dot is-active" type="button" data-slide="0" aria-label="第 1 張"></button>
            <button class="hero-slider__dot" type="button" data-slide="1" aria-label="第 2 張"></button>
            <button class="hero-slider__dot" type="button" data-slide="2" aria-label="第 3 張"></button>
          </div>
        </section>

        <!-- 商品區標題與快速入口 -->
        <div class="catalog-head">
          <div>
            <h1 class="catalog-title">SUPPLEMENT.<br>SHOP CLEAN.</h1>
          </div>
          <a class="accent-btn" href="#productGrid">查看本週熱賣</a>
        </div>

        <!-- 分類篩選與排序 -->
        <div class="toolbar">
          <div class="category-row" id="categoryRow">
            <button class="category-pill is-active" type="button" data-category="all">全部</button>
            <button class="category-pill" type="button" data-category="protein">高蛋白</button>
            <button class="category-pill" type="button" data-category="performance">訓練補給</button>
            <button class="category-pill" type="button" data-category="wellness">日常營養</button>
            <button class="category-pill" type="button" data-category="sports">運動用品</button>
            <button class="category-pill" type="button" data-category="accessories">沖泡配件</button>
          </div>
          <div class="sort-box">
            <span>排序</span>
            <select id="sortSelect">
              <option value="featured">精選推薦</option>
              <option value="price-low">價格低到高</option>
              <option value="price-high">價格高到低</option>
            </select>
          </div>
        </div>

        <!-- 主打商品區 -->
        <div class="featured-band">
          <div class="featured-visual">
            <div class="featured-copy">
              <div class="eyebrow">Bundle Pick</div>
              <h2>DAILY STACK<br>START SET</h2>
              <p>先把最常見的補給組起來。從訓練後蛋白、力量期肌酸，到平常保養用的魚油與綜合維他命一次補齊。</p>
            </div>
          </div>
          <div class="featured-panel">
            <div class="deal-box">
              <div class="eyebrow"
                style="background: var(--color-accent-soft); color: var(--color-black); border-color: transparent;">
                本週組合價</div>
              <h3>補給入門組</h3>
              <p><strong>乳清蛋白、肌酸、魚油</strong>與<strong>搖搖杯</strong>一次備齊，適合剛開始規律訓練、想把基本補給先建立起來的使用者。</p>
              <div class="deal-price">NT$ 3,280 <span>NT$ 3,940</span></div>
              <button class="accent-btn" id="bundleCheckoutBtn" type="button">直接結帳</button>
            </div>
            <div class="service-box">
              <h3>現貨出貨 / 效期標示</h3>
              <p>全站滿 NT$ 2,000 免運。補給品頁面會標示口味與有效日期區間，避免使用者下單後還要另外確認。</p>
            </div>
          </div>
        </div>

        <!-- 商品區分類頁首：顯示目前分類，並提供第二排快速切換按鈕 -->
        <section class="results-shell" id="resultsShell">
          <div class="results-head">
            <div>
              <div class="results-kicker">Current Category</div>
              <h2 class="results-title" id="resultsTitle">全部商品</h2>
              <p class="results-copy" id="resultsCopy">目前顯示全部補給品、營養品、運動用品與沖泡配件，方便先快速瀏覽完整商品列表。
                (瀏覽圖皆為示意圖)</p>
            </div>
          </div>
        </section>

        <!-- 商品列表 -->
        <div class="product-grid" id="productGrid">
        </div>

        <!-- 補充購物資訊 -->
        <div class="benefit-grid">
          <div class="benefit-box">
            <h3>補給分流</h3>
            <p>我們將產品分為「高蛋白」、「訓練補給」、「日常營養」三大類
              讓你不用先理解所有補給品，也能依照目前目標快速選擇。</p>
          </div>
          <div class="benefit-box">
            <h3>搭配推薦</h3>
            <p>一次買齊最有效
              常見補給組合幫你直接配好!</p>
          </div>
          <div class="benefit-box">
            <h3>口味與效期</h3>
            <p>每一款產品皆清楚標示口味、容量與效期
              讓你安心選擇、放心補給。</p>
          </div>
        </div>
      </section>

    </main>

    <!-- 購物車抽屜 -->
    <!-- 購物車遮罩與右側抽屜 -->
    <div class="cart-overlay" id="cartOverlay" aria-hidden="true">
      <aside class="summary-card" aria-label="購物車與結帳摘要">
        <button class="cart-close" id="cartClose" type="button" aria-label="關閉購物車">✕</button>

        <div class="summary-head">
          <div>
            <div class="summary-kicker">Current Cart</div>
            <h3>今日結帳摘要</h3>
          </div>
          <strong id="cartItemsLabel">3 Items</strong>
        </div>

        <!-- 購物車商品清單由 shop.js 動態產生 -->
        <div class="summary-list" id="summaryList"></div>

        <div class="summary-row"><span>商品金額</span><strong id="subtotalValue">0</strong></div>
        <div class="summary-row"><span>宅配運費</span><strong id="shippingValue">0</strong></div>
        <div class="summary-row"><span>會員折扣</span><strong id="discountValue">0</strong></div>
        <div class="summary-row"><span>應付總額</span><strong id="totalValue">0</strong></div>

        <div class="cart-actions">
          <button class="accent-btn" id="checkoutBtn" type="button">前往結帳</button>
          <button class="clear-cart-btn" id="clearCartBtn" type="button">刪除購物車內所有商品</button>
        </div>

        <!-- 可改成 JS 變數控制的出貨提示文字 -->
        <div class="status-box" id="statusBox">
          今日 16:00 前下單可安排明日出貨。補給品會優先依口味與批號出貨。
        </div>
      </aside>
    </div>
  </div>

  <!-- 右下角快速回到電商首頁 -->
  <button class="back-home-btn" id="backHomeBtn" type="button" aria-label="回到電商首頁">
    ↑
  </button>

  <!-- footer區域 -->
  <footer class="site-footer">
    <div class="footer-main">

      <!-- 左:品牌區 -->
      <div class="footer-brand">
        <!-- Logo -->
        <div class="brand">
          KATACH
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
              <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
              <rect x="11" y="20" width="6" height="40" fill="currentColor" />
              <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
              <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
            </svg>
          </span>
          SHOP
        </div>
        <p>專為訓練者設計的補給品平台，提供高蛋白、肌酸、魚油與日常營養品，讓你專注在每一次的訓練!</p>
      </div>

      <!-- 中:快速連結 -->
      <div class="footer-col">
        <h4>商品分類</h4>
        <ul>
            <li><a asp-controller="Shop" asp-action="Index" asp-route-category="protein">高蛋白</a></li>
            <li><a asp-controller="Shop" asp-action="Index" asp-route-category="performance">訓練補給</a></li>
            <li><a asp-controller="Shop" asp-action="Index" asp-route-category="wellness">日常營養</a></li>
            <li><a asp-controller="Shop" asp-action="Index" asp-route-category="sports">運動用品</a></li>
            <li><a asp-controller="Shop" asp-action="Index" asp-route-category="accessories">沖泡配件</a></li>
        </ul>
      </div>

      <!-- 右:服務資訊 -->
      <div class="footer-col">
        <h4>服務資訊</h4>
        <ul>
          <li><a href="#">常見問題</a></li>
          <li><a href="#">配送說明</a></li>
          <li><a href="#">退換貨政策</a></li>
          <li><a asp-controller="Account" asp-action="Index">會員登入</a></li>
        </ul>
      </div>

      <!-- 右:聯絡資訊 -->
      <div class="footer-col">
        <h4>聯絡我們</h4>
        <ul>
          <li>service@katachi.tw</li>
          <li>週一至週五 10:00–18:00</li>
        </ul>
      </div>

    </div>

    <!-- 底部版權列 -->
    <div class="footer-bottom">
      <span>© 2024 KATACHI SHOP. All rights reserved.</span>
      <div class="footer-links">
        <a href="#">隱私權政策</a>
        <a href="#">服務條款</a>
      </div>
    </div>
  </footer>

  <!-- 電商頁主要互動邏輯 -->
                                            <script src="~/katachi-shop/js/product-data.js" asp-append-version="true"></script>
                                            <script src="~/katachi-shop/js/shop.js" asp-append-version="true"></script>


</body>

</html>




