@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>訂單確認 | KATACHI SHOP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Noto+Sans+JP:wght@100;200;300;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true">
  <link rel="stylesheet" href="~/katachi-shop/css/order-complete.css" asp-append-version="true">
</head>

<body>

    <!-- 頂部導覽 -->
    <header class="checkout-topbar">
        <a class="brand" asp-controller="Home" asp-action="Index">
            KATACH
            <span class="brand-mark" aria-hidden="true">
                <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
                    <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
                    <rect x="11" y="20" width="6" height="40" fill="currentColor" />
                    <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
                    <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
                </svg>
            </span>
            SHOP
        </a>

        <!-- 進度步驟 -->
        <div class="checkout-steps">
            <div class="step is-done">
                <span class="step-num"><i class="fa fa-check"></i></span>
                <span class="step-label">購物車</span>
            </div>
            <div class="step-line"></div>
            <div class="step is-done">
                <span class="step-num"><i class="fa fa-check"></i></span>
                <span class="step-label">結帳</span>
            </div>
            <div class="step-line"></div>
            <div class="step is-active">
                <span class="step-num"><i class="fa fa-check"></i></span>
                <span class="step-label">完成</span>
            </div>
        </div>

        <a class="ghost-btn" asp-controller="Shop" asp-action="MyOrders">我的訂單</a>
    </header>

    <main class="complete-page">

        <!-- 成功提示 -->
        <div class="complete-hero">
            <div class="complete-icon"><i class="fa fa-check-circle"></i></div>
            <h1 class="complete-title">訂單已成立！</h1>
            <p class="complete-subtitle">
                感謝您的購買，我們將盡快為您安排出貨。<br>
                訂單確認信已寄送至您的電子郵件。
            </p>
            <div class="order-num-badge" id="displayOrderNum">#KT-000000</div>
        </div>

        <!-- 訂單明細 -->
        <div class="complete-summary">
            <div class="summary-head">訂單明細</div>
            <div class="summary-items" id="completeItems">
                <div style="color:var(--color-grey-mid);font-size:var(--text-sub);padding:8px 0;">載入中…</div>
            </div>
            <div class="price-section" id="completePrices"></div>
        </div>

        <!-- 收件資訊 -->
        <div class="ship-info" id="completeShipInfo">
            <div class="ship-info__title">收件資訊</div>
        </div>

        <!-- 操作按鈕 -->
        <div class="complete-actions">
            <a class="accent-btn" asp-controller="Shop" asp-action="Index">
                <i class="fa fa-shopping-bag"></i> 繼續購物
            </a>
            <a class="ghost-btn" asp-controller="Shop" asp-action="MyOrders">查看我的訂單</a>
            <a class="ghost-btn" asp-controller="Home" asp-action="Index">回到首頁</a>
        </div>

    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="footer-main">
            <div class="footer-brand">
                <div class="brand" style="color:var(--color-white);">
                    KATACH
                    <span class="brand-mark" aria-hidden="true">
                        <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
                            <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
                            <rect x="11" y="20" width="6" height="40" fill="currentColor" />
                            <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
                            <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
                        </svg>
                    </span>
                    SHOP
                </div>
                <p>專為訓練者設計的補給品平台，提供高蛋白、肌酸、魚油與日常營養品，讓你專注在每一次的訓練!</p>
            </div>
            <div class="footer-col">
                <h4>商品分類</h4>
                <ul>
                    <li><a asp-controller="Shop" asp-action="Index" asp-route-category="protein">高蛋白</a></li>
                    <li><a asp-controller="Shop" asp-action="Index" asp-route-category="performance">訓練補給</a></li>
                    <li><a asp-controller="Shop" asp-action="Index" asp-route-category="wellness">日常營養</a></li>
                    <li><a asp-controller="Shop" asp-action="Index" asp-route-category="accessories">沖泡配件</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>服務資訊</h4>
                <ul>
                    <li><a href="#">常見問題</a></li>
                    <li><a href="#">配送說明</a></li>
                    <li><a href="#">退換貨政策</a></li>
                    <li><a asp-controller="Account" asp-action="Index">會員登入</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>聯絡我們</h4>
                <ul>
                    <li>service@katachi.tw</li>
                    <li>週一至週五 10:00–18:00</li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <span>© 2024 KATACHI SHOP. All rights reserved.</span>
            <div class="footer-links">
                <a href="#">隱私權政策</a>
                <a href="#">服務條款</a>
            </div>
        </div>
    </footer>

    <script src="~/katachi-shop/js/order-complete.js" asp-append-version="true"></script>


</body>
</html>






