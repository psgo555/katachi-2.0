@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW">

<head>
  <!-- 基本頁面設定與登入頁樣式載入 -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>會員登入 | KATACHI SHOP</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Noto+Sans+JP:wght@100;200;300;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <link rel="stylesheet" href="~/css/tokens.css" asp-append-version="true">
  <link rel="stylesheet" href="~/katachi-shop/css/login.css" asp-append-version="true">
</head>

<body>
  <header class="auth-shop-nav">
    <a class="auth-shop-brand" asp-controller="Home" asp-action="Index">
      KATACH
      <span class="auth-brand-mark" aria-hidden="true">
        <svg viewBox="0 0 28 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
          <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
          <rect x="11" y="20" width="6" height="40" fill="currentColor" />
          <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
          <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
        </svg>
      </span>
      SHOP
    </a>
    <nav class="auth-shop-actions" aria-label="會員導覽">
      <a class="auth-nav-link" asp-controller="Shop" asp-action="Index">商店</a>
      <a class="auth-nav-link is-active" asp-controller="Account" asp-action="Index">會員</a>
    </nav>
  </header>

  <div class="login-shell">
    <!-- 左側視覺區：品牌、標題與快速入口 -->
    <section class="login-visual">
      <div class="visual-top-spacer" aria-hidden="true"></div>

      <div class="visual-copy">
        <div class="eyebrow">Member Access</div>
        <h1 class="visual-title">SIGN IN.<br>TRAIN ON.</h1>
      </div>

      <div class="visual-links">
          <a class="visual-link" asp-controller="Shop" asp-action="Index">返回商店</a>
          <a class="visual-link" asp-controller="Account" asp-action="Index" asp-route-tab="register">建立帳號</a>
      </div>
    </section>

    <!-- 右側表單區：目前為前端示意版 -->
    <section class="login-panel">
      <div class="login-form-wrap">
        <div class="panel-kicker">KATACHI MEMBER</div>
        <h2 class="panel-title">登入會員</h2>
        <!-- 錯誤訊息 -->
        <div class="auth-error" id="loginError" style="display:none;background:var(--color-danger-bg);border:1px solid var(--color-danger-line);color:var(--color-danger-text);padding:12px 16px;border-radius:4px;font-size:0.85rem;margin-bottom:16px;">
          <i class="fa fa-exclamation-circle"></i> <span id="loginErrorMsg">帳號或密碼有誤，請重新輸入。</span>
        </div>

        <!-- 登入表單 -->
        <form class="login-form" id="loginForm" novalidate>
          <div class="field-group">
            <label class="field-label" for="login-email">電子郵件</label>
            <input class="field-input" id="login-email" type="email" placeholder="name@example.com" autocomplete="email">
          </div>

          <div class="field-group">
            <label class="field-label" for="login-password">密碼</label>
            <div style="position:relative;">
              <input class="field-input" id="login-password" type="password" placeholder="請輸入密碼" autocomplete="current-password" style="padding-right:44px;">
              <button type="button" id="togglePw" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--color-grey-mid);font-size:1rem;padding:0;" aria-label="顯示密碼">
                <i class="fa fa-eye"></i>
              </button>
            </div>
          </div>

          <div class="field-row">
            <label class="checkbox-row">
              <input type="checkbox" id="rememberMe">
              <span>記住我</span>
            </label>
            <a class="text-link" href="#">忘記密碼？</a>
          </div>

          <button class="primary-btn" type="submit" id="loginBtn">
            登入帳號 <i class="fa fa-arrow-right" style="margin-left:8px;"></i>
          </button>

          <div class="divider">或使用其他方式</div>

          <div class="social-row">
            <button class="secondary-btn" type="button"><i class="fa fa-google" style="margin-right:6px;"></i> Google 登入</button>
            <button class="secondary-btn" type="button"><i class="fa fa-facebook" style="margin-right:6px;"></i> Facebook</button>
          </div>
        </form>

        <div class="foot-row">
          <span>還沒有帳號？</span>
          <a class="text-link" asp-controller="Account" asp-action="Index" asp-route-tab="register">立即免費註冊</a>
        </div>
      </div>
    </section>
  </div>
  <!-- Footer -->
  <footer class="login-footer" style="background:var(--color-black);color:var(--color-white-mute);font-family:var(--font-sans);font-weight:var(--weight-light);">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 80px;border-top:1px solid rgba(255,255,255,0.2);font-size:0.85rem;">
      <span>© 2024 KATACHI SHOP. All rights reserved.</span>
      <div style="display:flex;gap:24px;">
        <a href="#" style="color:rgba(255,255,255,0.6);text-decoration:none;">隱私權政策</a>
        <a href="#" style="color:rgba(255,255,255,0.6);text-decoration:none;">服務條款</a>
      </div>
    </div>
  </footer>

  <!-- 登入頁互動邏輯 -->
  <script src="~/katachi-shop/js/login.js" asp-append-version="true"></script>
</body>

</html>



