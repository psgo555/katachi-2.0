<!-- ─────────────────────────────────────────
       MODAL ADD：新增訓練項目
       ─ 動作 chip 選擇
       ─ 重量輸入
       ─ 組數 / 次數步進控制
       ───────────────────────────────────────── -->
<div class="mo" id="mo-add">
    <div class="mb lg">
        <div class="mhead">
            <div class="mtitle">新增訓練項目</div>
            <button class="mclose" id="mo-add-close">X</button>
        </div>
        <!-- 選取日期顯示（由 JS 注入） -->
        <div style="font-size:18px;color:var(--text-dim);font-family:var(--font-sans);margin-bottom:18px"
             id="mo-add-date"></div>

        <!-- 動作選擇 grid（部位 × 器材） -->
        <div class="msec">
            <div class="ex-grid">
                <div class="ex-grid-head">
                    <div class="ex-grid-corner"></div>
                    <div class="eq-col-lbl">槓鈴</div>
                    <div class="eq-col-lbl">啞鈴</div>
                    <div class="eq-col-lbl">徒手</div>
                    <div class="eq-col-lbl">機械</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">背</div>
                    <div class="ex-cell" data-ex="row-bar">槓鈴划船</div>
                    <div class="ex-cell" data-ex="row-db">單手啞鈴划船</div>
                    <div class="ex-cell" data-ex="pullup">引體向上</div>
                    <div class="ex-cell" data-ex="lat">滑輪下拉</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">胸</div>
                    <div class="ex-cell" data-ex="bench-bar">槓鈴臥推</div>
                    <div class="ex-cell" data-ex="bench-db">啞鈴臥推</div>
                    <div class="ex-cell" data-ex="pushup">伏地挺身</div>
                    <div class="ex-cell" data-ex="chestpress">胸推機</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">核心</div>
                    <div class="ex-cell" data-ex="rollout">槓鈴滾輪</div>
                    <div class="ex-cell" data-ex="sidebend">啞鈴側彎</div>
                    <div class="ex-cell" data-ex="plank">棒式</div>
                    <div class="ex-cell" data-ex="crunch">捲腹機</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">肩</div>
                    <div class="ex-cell" data-ex="ohp-bar">槓鈴肩推</div>
                    <div class="ex-cell" data-ex="lateral-db">啞鈴側平舉</div>
                    <div class="ex-cell" data-ex="hspu">倒立撐</div>
                    <div class="ex-cell" data-ex="shoulderpress">肩推機</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">臂</div>
                    <div class="ex-cell" data-ex="curl-bar">槓鈴彎舉</div>
                    <div class="ex-cell" data-ex="curl-db">啞鈴彎舉</div>
                    <div class="ex-cell" data-ex="dip">雙槓撐體</div>
                    <div class="ex-cell" data-ex="curl-mach">二頭彎舉機</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">腿</div>
                    <div class="ex-cell" data-ex="squat-bar">槓鈴深蹲</div>
                    <div class="ex-cell" data-ex="squat-db">啞鈴深蹲</div>
                    <div class="ex-cell" data-ex="squat-bw">自重深蹲</div>
                    <div class="ex-cell" data-ex="legpress">腿推機</div>
                </div>
                <div class="ex-grid-row">
                    <div class="ex-row-lbl">臀</div>
                    <div class="ex-cell" data-ex="hipthrust-bar">槓鈴臀推</div>
                    <div class="ex-cell" data-ex="hipthrust-db">啞鈴臀推</div>
                    <div class="ex-cell" data-ex="glutebridge">臀橋</div>
                    <div class="ex-cell" data-ex="abduction">臀外展機</div>
                </div>
            </div>
        </div>

        <!-- 重量 / 次數 / 組數（橫向三欄） -->
        <div class="msec">
            <div class="add-ctrl-row">
                <div class="add-ctrl-grp">
                    <div class="add-ctrl-lbl">重量</div>
                    <input class="winp add-winp" type="number" id="winp" placeholder="60" min="0" step="2.5">
                    <div class="w-mode-lbl" id="w-mode-lbl"></div>
                </div>
                <div class="add-ctrl-grp">
                    <div class="add-ctrl-lbl">次數</div>
                    <div class="num-ctrl">
                        <button class="num-btn" data-t="reps" data-d="-">-</button>
                        <div class="num-val" id="reps-v">8</div>
                        <button class="num-btn" data-t="reps" data-d="+">+</button>
                    </div>
                </div>
                <div class="add-ctrl-grp">
                    <div class="add-ctrl-lbl">組數</div>
                    <div class="num-ctrl">
                        <button class="num-btn" data-t="sets" data-d="-">-</button>
                        <div class="num-val" id="sets-v">3</div>
                        <button class="num-btn" data-t="sets" data-d="+">+</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 確認加入項目按鈕 -->
        <button class="msub" id="mo-add-sub">加入項目</button>
    </div>
</div>

<!-- ─────────────────────────────────────────
       MODAL SETS：組數詳情
       ─ 點擊訓練項目列後開啟
       ─ 顯示各組重量 × 次數 + 完成勾選
       ───────────────────────────────────────── -->
<div class="mo" id="mo-sets">
    <div class="mb sm">
        <div class="mhead">
            <div class="mtitle" id="sets-title">訓練組</div>
            <div style="display:flex;align-items:center;gap:16px">
                <button class="mbtn mbtn-sm mbtn-danger" id="sets-delete">刪除項目</button>
                <button class="mclose" id="mo-sets-close">X</button>
            </div>
        </div>
        <!-- 組數列表（由 JS renderSets() 動態注入） -->
        <div id="sets-list"></div>
        <!-- 底部操作列 -->
        <div class="mfoot">
            <button class="mbtn" id="sets-complete-all">全部完成</button>
            <button class="mbtn" id="sets-confirm">確定</button>
        </div>
    </div>
</div>

<script>
    const SERVER_PR = @Html.Raw(JsonSerializer.Serialize(Model.PrList, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
    const SERVER_RM = @Html.Raw(JsonSerializer.Serialize(Model.RmList, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
    const SERVER_ACTIVITY = @Html.Raw(JsonSerializer.Serialize(Model.Activity, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
    const SERVER_TD = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyData));
    const SERVER_MONTHS = @Html.Raw(JsonSerializer.Serialize(Model.AvailableMonths));
    const SERVER_YEARS = @Html.Raw(JsonSerializer.Serialize(Model.AvailableYears));
    const SERVER_WEIGHTED_DATA = @Html.Raw(JsonSerializer.Serialize(Model.WeightedData));
    const SERVER_PRIMARY_DATA  = @Html.Raw(JsonSerializer.Serialize(Model.PrimaryData));
</script>