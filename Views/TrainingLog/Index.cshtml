@model katachi.Models.Training.TrainingLogViewModel
@using System.Text.Json
@section Styles {
    <link rel="stylesheet" href="~/css/base/main.css" />
    <link rel="stylesheet" href="~/css/pages/trainingLog/overview.css" />
    <link rel="stylesheet" href="~/css/pages/trainingLog/calendar.css" />
    <link rel="stylesheet" href="~/css/pages/trainingLog/detail.css" />
    <link rel="stylesheet" href="~/css/pages/trainingStats.css" />
    <link rel="stylesheet" href="~/css/pages/muscleAnalysis.css" />
    <link rel="stylesheet" href="~/css/pages/userSettings.css" />
    <link rel="stylesheet" href="~/css/components/form.css" />
    <link rel="stylesheet" href="~/css/components/modal.css" />
    <link rel="stylesheet" href="~/css/components/stepper.css" />
    <link rel="stylesheet" href="~/css/components/workoutSets.css" />
    
}
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" defer></script>
    <script src="~/js/data.js" defer></script>
    <script src="~/js/utils.js" defer></script>
    <script src="~/js/pages/trainingLog.js" defer></script>
    <script src="~/js/pages/trainingStats.js" defer></script>
    <script src="~/js/pages/muscleAnalysis.js" defer></script>
    <script src="~/js/main.js" defer></script>
}

<!-- ===============================================================
       版面骨架：sidebar-l | main | sidebar-r
       =============================================================== -->
<div class="layout">
    <div class="sidebar-l">
        <div class="sidebar-hero">
            <h2 class="sidebar-hero-title">FORGE<br>YOUR FORM</h2>
            <div class="sidebar-tag">形を鍛える</div>
            <div class="coord-label">
                <span class="coord-line"></span>
                <span class="coord-numbers">35.7° N / 139.7° E</span>
            </div>
        </div>
        <div class="sidebar-divider"></div>
        <div class="subnav">
            <button class="subnav-tab active" data-page="p1">
                <span class="subnav-tag">[ 01 ]</span>
                <div class="subnav-text">
                    <span class="subnav-en">TRAINING LOG</span>
                    <span class="subnav-jp">訓練日誌</span>
                </div>
            </button>
            <button class="subnav-tab" data-page="p2">
                <span class="subnav-tag">[ 02 ]</span>
                <div class="subnav-text">
                    <span class="subnav-en">ANALYTICS</span>
                    <span class="subnav-jp">訓練統計</span>
                </div>
            </button>
            <button class="subnav-tab" data-page="p3">
                <span class="subnav-tag">[ 03 ]</span>
                <div class="subnav-text">
                    <span class="subnav-en">MUSCLE MAP</span>
                    <span class="subnav-jp">肌群分析</span>
                </div>
            </button>
            <button class="subnav-tab" data-page="p4">
                <span class="subnav-tag">[ 04 ]</span>
                <div class="subnav-text">
                    <span class="subnav-en">GOALS</span>
                    <span class="subnav-jp">目標設定</span>
                </div>
            </button>
        </div>
    </div>
    <div class="main">


        <!-- ═══════════════════════════════════════
           PAGE 1：訓練日誌
           ─ 上半：PR/RM 最佳記錄 + 完成率/活躍度
           ─ 中：月曆
           ─ 下：選取日期詳情 + 新增按鈕
           ═══════════════════════════════════════ -->
        <div class="page active" id="page-p1">
            <div class="pi">

                <!-- P1 上方雙欄：左＝PR/RM，右＝完成率/活躍度 -->
                <div class="p1-top">

                    <!-- 左卡：訓練活躍度 -->
                    <div class="card">
                        <div class="sec-label" style="margin-bottom:14px">訓練活躍度</div>
                        <div class="act-view" style="display:block;padding-top:0">
                            <div class="act-quad">
                                <div class="act-item">
                                    <div><span class="act-num" id="act-next">—</span><span class="act-unit" id="act-next-unit"></span></div>
                                    <div class="act-lbl">下次安排距今</div>
                                </div>
                                <div class="act-item">
                                    <div><span class="act-num" id="act-last">—</span><span class="act-unit" id="act-last-unit"></span></div>
                                    <div class="act-lbl">上次訓練距今</div>
                                </div>
                                <div class="act-item">
                                    <div><span class="act-num" id="act-streak">—</span><span class="act-unit"> 週</span></div>
                                    <div class="act-lbl">連續訓練週數</div>
                                </div>
                                <div class="act-item">
                                    <div><span class="act-num" id="act-sets">—</span><span class="act-unit"> 組</span></div>
                                    <div class="act-lbl">本月完成組數</div>
                                </div>
                                <div class="act-item">
                                    <div><span class="act-num" id="act-rest">—</span><span class="act-unit"> 天</span></div>
                                    <div class="act-lbl">本月休息天數</div>
                                </div>
                                <div class="act-item">
                                    <div><span class="act-num" id="act-avg">—</span><span class="act-unit"> 天</span></div>
                                    <div class="act-lbl">本月週均訓練天數</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 右卡：完成率 / 訓練活躍度（兩個 view，JS 切換顯示） -->
                    <div class="card">
                        
                        <div class="sec-label" style="margin-bottom:14px">完成率</div>
                        <!-- 完成率視圖（預設顯示） -->
                        <div class="cmp-view" id="cmp-view">
                            <!-- 頂列：大百分比（左）＋ 完成/計畫比（右） -->
                            <div class="cmp-top-row">
                                <div class="cmp-right">
                                    <div class="cmp-frac" id="cmp-frac">0 / 0</div>
                                    <div class="cmp-frac-lbl">已完成 / 已安排</div>
                                </div>
                                <div class="cmp-pct">
                                    <div class="cmp-big">
                                        <div class="cmp-num" id="cmp-num">0</div>
                                        <div class="cmp-sym">%</div>
                                    </div>
                                    <div class="cmp-sub" id="cmp-sub-lbl">完成率 · 2026年 04月</div>
                                </div>
                            </div>
                            <!-- 進度條（寬度由 JS 設定） -->
                            <div class="prog-bar">
                                <div class="prog-fill" id="cmp-bar" style="width:0%"></div>
                            </div>
                            <!-- 三格統計：待完成 / 部分完成 / 未完成 -->
                            <div class="trio">
                                <div class="trio-item">
                                    <div class="trio-num" style="color:var(--text-dim)" id="st-upcoming">-</div>
                                    <div class="trio-lbl">待完成 (未來已安排)</div>
                                </div>
                                <div class="trio-item">
                                    <div class="trio-num" style="color:var(--partial)" id="st-partial">-</div>
                                    <div class="trio-lbl">部分完成</div>
                                </div>
                                <div class="trio-item">
                                    <div class="trio-num" style="color:var(--danger)" id="st-miss">-</div>
                                    <div class="trio-lbl">未完成 (過去未訓練)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 月曆區段 -->
                <div class="cal-section">
                    <!-- 月份導覽 + 圖例 -->
                    <div class="cal-header">
                        <div class="cal-mnav">
                            <button class="cal-nb" id="cal-prev">&#8249;</button>
                            <div class="cal-mlbl" id="cal-mlbl">2026年 04月</div>
                            <button class="cal-nb" id="cal-next">&#8250;</button>
                        </div>
                        <!-- 色塊圖例：完成 / 部分 / 計畫 / 未完成 -->
                        <div class="cal-legend">
                            <div class="leg-item">
                                <div class="leg-dot" style="background:var(--done)"></div>已完成
                            </div>
                            <div class="leg-item">
                                <div class="leg-dot" style="background:var(--partial)"></div>部分完成
                            </div>
                            <div class="leg-item">
                                <div class="leg-dot" style="background:var(--planned)"></div>已安排
                            </div>
                            <div class="leg-item">
                                <div class="leg-dot" style="background:var(--missed);border:1px solid var(--danger)"></div>未完成
                            </div>
                        </div>
                    </div>
                    <!-- 日曆本體 -->
                    <div class="cal-wrap">
                        <!-- 星期標頭列 -->
                        <div class="cal-dow">
                            <div class="cal-dow-cell">日</div>
                            <div class="cal-dow-cell">一</div>
                            <div class="cal-dow-cell">二</div>
                            <div class="cal-dow-cell">三</div>
                            <div class="cal-dow-cell">四</div>
                            <div class="cal-dow-cell">五</div>
                            <div class="cal-dow-cell">六</div>
                        </div>
                        <!-- 日期格子（由 JS renderCal() 動態注入） -->
                        <div class="cal-cells" id="cal-cells"></div>
                    </div>
                </div>

                <!-- 選取日期詳情面板 + 新增按鈕 -->
                <div>
                    <div class="detail-panel">
                        <!-- 頂列：日期文字 + 狀態徽章 -->
                        <div class="detail-topbar">
                            <div class="detail-date" id="detail-date">2026.04.15</div>
                            <div class="dbadge none" id="dbadge">未安排</div>
                        </div>
                        <!-- 訓練項目列表（由 JS renderDetail() 動態注入） -->
                        <div id="ex-wrap"></div>
                    </div>
                    <!-- 新增訓練項目按鈕（開啟 mo-add 彈窗） -->
                    <button class="add-btn" id="add-btn">+ 新增訓練項目</button>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════
           PAGE 2：訓練統計
           ─ 控制列：指標切換 + 動作選擇 + 月/年
           ─ 雙折線圖：對比月 vs 主月
           ─ 本月摘要表格
           ═══════════════════════════════════════ -->
        <div class="page" id="page-p2">
            <div class="pi">

                <!-- 控制列：三欄 grid — 左：動作選單 / 中：指標切換 / 右：月年切換 -->
                <div class="p2-ctrl">
                    <!-- 左：動作選單（決定圖表顯示哪個訓練動作） -->
                    <select class="exsel" id="p2-ex">
                        <optgroup label="背">
                            <option value="row-bar">槓鈴划船</option>
                            <option value="row-db">單手啞鈴划船</option>
                            <option value="pullup">引體向上</option>
                            <option value="lat">滑輪下拉</option>
                        </optgroup>
                        <optgroup label="胸">
                            <option value="bench-bar">槓鈴臥推</option>
                            <option value="bench-db">啞鈴臥推</option>
                            <option value="pushup">伏地挺身</option>
                            <option value="chestpress">胸推機</option>
                        </optgroup>
                        <optgroup label="核心">
                            <option value="rollout">槓鈴滾輪</option>
                            <option value="sidebend">啞鈴側彎</option>
                            <option value="plank">棒式</option>
                            <option value="crunch">捲腹機</option>
                        </optgroup>
                        <optgroup label="肩">
                            <option value="ohp-bar">槓鈴肩推</option>
                            <option value="lateral-db">啞鈴側平舉</option>
                            <option value="hspu">倒立撐</option>
                            <option value="shoulderpress">肩推機</option>
                        </optgroup>
                        <optgroup label="臂">
                            <option value="curl-bar">槓鈴彎舉</option>
                            <option value="curl-db">啞鈴彎舉</option>
                            <option value="dip">雙槓撐體</option>
                            <option value="curl-mach">二頭彎舉機</option>
                        </optgroup>
                        <optgroup label="腿">
                            <option value="squat-bar">槓鈴深蹲</option>
                            <option value="squat-db">啞鈴深蹲</option>
                            <option value="squat-bw">自重深蹲</option>
                            <option value="legpress">腿推機</option>
                        </optgroup>
                        <optgroup label="臀">
                            <option value="hipthrust-bar">槓鈴臀推</option>
                            <option value="hipthrust-db">啞鈴臀推</option>
                            <option value="glutebridge">臀橋</option>
                            <option value="abduction">臀外展機</option>
                        </optgroup>
                    </select>
                    <!-- 中：指標切換，置中 -->
                    <div class="seg" id="ctrl-metric">
                        <button class="seg-btn active" data-v="weight">最高重量</button>
                        <button class="seg-btn" data-v="rm">最大重複</button>
                        <button class="seg-btn" data-v="volume">總訓練量</button>
                    </div>
                    <!-- 右：月 / 年檢視切換 -->
                    <div class="p2-ctrl-right">
                        <div class="seg" id="ctrl-period">
                            <button class="seg-btn active" data-v="month">月檢視</button>
                            <button class="seg-btn" data-v="year">年檢視</button>
                        </div>
                    </div>
                </div>

                <!-- 雙折線圖：左＝對比期，右＝主期 -->
                <div class="p2-charts">
                    <!-- 左圖：月份選單（月檢視）/ 年份選單（年檢視） -->
                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div class="chart-card-title" id="p2-lt">對比月</div>
                            <select class="msel" id="p2-lm"></select>
                            <select class="msel" id="p2-ly" style="display:none"></select>
                        </div>
                        <canvas id="chart-l" height="260"></canvas>
                    </div>
                    <!-- 右圖：月份選單（月檢視）/ 年份選單（年檢視） -->
                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div class="chart-card-title" id="p2-rt">主月</div>
                            <select class="msel" id="p2-rm"></select>
                            <select class="msel" id="p2-ry" style="display:none"></select>
                        </div>
                        <canvas id="chart-r" height="260"></canvas>
                    </div>
                </div>

                <!-- 本月摘要：三欄對比表格（由 JS renderSummary() 動態注入） -->
                <div class="p2-summary">
                    <div class="p2-sum-topbar">
                        <div class="sec-label">本月摘要</div>
                        <div class="p2-sum-formula" id="p2-sum-formula"></div>
                    </div>
                    <div class="p2-sum-grid" id="p2-sum-grid"></div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════
           PAGE 3：肌群分析
           ─ 左：人體 SVG（正面/背面切換）+ 圖例
           ─ 右：訓練佔比圓餅圖 / 目標達成率 / 本月建議
           ═══════════════════════════════════════ -->
        <div class="page" id="page-p3">
            <div class="pi">
                <div class="p3-grid">

                    <!-- 左欄：人體肌群熱力圖 -->
                    <div class="muscle-card">
                        <div class="sec-label" id="p3-month-label">肌群分布圖 · 2026年 04月</div>
                        <!-- 正面 / 背面切換 + 月份滾輪選單 -->
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:20px">
                            <div class="body-tog">
                                <button class="body-tog-btn active" data-side="front">正面</button>
                                <button class="body-tog-btn" data-side="back">背面</button>
                            </div>
                            <select id="p3-msel" class="msel"></select>
                        </div>
                        <!-- 正面 SVG（預設顯示；肌群 fill 由 JS muColor() 動態設定） -->
                        <div class="body-fig active" id="fig-front">
                            <div class="bsvg-wrap">
                                <!-- 正面圖 -->
                                <div class="body-map__figure">
                                    <img class="body-map__image" src="~/training-svg/front.svg" alt="front body map" />
                                    <!-- 互動 SVG 覆蓋層 -->
                                    <svg class="body-map__overlay" viewBox="0 0 340 649" xmlns="http://www.w3.org/2000/svg">

                                        <!-- 斜方肌 -->
                                        <g class="muscle-pair" data-muscle="frontTrapezius" role="button" tabIndex="0"
                                               transform="translate(117, 97) scale(1)">
                                            <!-- 左 -->
                                            <path d="M9.373 10.9756C14.528 7.9436 20.321 4.5296 22.246 3.3876C27.74 0.130004 28.246 0.434004 28.246 6.9976C28.246 15.5356 26.786 18.8296 21.886 21.3376C19.61 22.5036 16.302 23.7856 14.536 24.1876L11.327 24.9176L9.858 22.6766C9.05 21.4446 6.502 19.5476 4.195 18.4616L0 16.4876L9.373 10.9756Z" />
                                            <!-- 右 -->
                                            <path d="M77.2461 6.50861C77.2461 17.1966 79.0601 19.6596 89.6181 23.3096L94.7461 25.0816L96.4171 23.1016C97.3361 22.0116 99.9411 20.0676 102.207 18.7806L106.326 16.4416L97.5361 11.4396C92.7011 8.68861 86.1581 4.9896 82.9961 3.219L77.2461 0V6.50861Z" />
                                        </g>
                                        <!-- 三角肌(左)-->
                                        <g class="muscle-pair" data-muscle="frontDeltoidLeft" role="button" tabIndex="0">
                                            <g transform="translate(71, 115.5) scale(0.87)">
                                                <path d="M13.4981 12.008C18.6791 7.108 28.4101 1.72701 33.9651 0.69101C35.3391 0.43501 40.0621 0.175007 44.4621 0.113007L52.4621 0L57.4501 2.726C60.1931 4.226 62.5621 6.128 62.7161 6.953C62.8691 7.778 61.6171 9.353 59.9352 10.453C55.1611 13.574 38.3651 34.928 31.4981 46.609C29.1031 50.682 24.5321 53.19 11.8171 57.406L1.50211 60.826L0.747132 59.64C-0.376868 57.871 -0.192895 42.179 1.03211 35.387C2.63411 26.507 7.17814 17.984 13.4981 12.008Z" />
                                            </g>
                                        </g>
                                        <!-- 三角肌(右) -->
                                        <g class="muscle-pair" data-muscle="frontDeltoidRight" role="button" tabIndex="0">
                                            <g transform="translate(68, 115.5) scale(0.87)">
                                                <path d="M169.063 6.30299C169.648 5.31199 172.106 3.488 174.525 2.25L178.924 0H187.03C206.483 0 220.914 8.848 227.596 24.871L230.777 32.5L231.273 43.628C231.545 49.749 231.462 56.387 231.088 58.38L230.409 62.004L227.655 60.58C226.14 59.797 221.773 58.158 217.95 56.937C209.752 54.321 201.5 50.353 201.5 49.028C201.5 48.512 197.946 42.773 193.602 36.274C186.055 24.984 174.255 11.434 170 9.17L168 8.10699L169.063 6.30299Z" />
                                            </g>
                                        </g>
                                        <!-- 二頭(左) -->
                                        <g class="muscle-pair" data-muscle="bicepsLeft" role="button" tabIndex="0">
                                            <!-- 左 -->
                                            <g transform="translate(64.5, 162) scale(0.84)">
                                                <path d="M23.9765 5.67923C30.2435 3.47523 35.8275 1.21524 36.3865 0.656237C37.8145 -0.771763 38.8255 0.118236 39.5565 3.44924C39.9035 5.02524 41.2875 7.80723 42.6335 9.63223L45.0815 12.9502V22.5452C45.0815 33.9152 43.3495 41.3002 38.2825 51.5372C31.9105 64.4082 15.5635 79.5242 7.98653 79.5522C1.66753 79.5742 -0.113489 73.1992 0.00551134 50.9812C0.106511 32.0082 0.838509 26.9302 4.50951 19.7362C8.25151 12.4022 11.4715 10.0772 23.9765 5.67923Z" />
                                            </g>
                                        </g>
                                        <!-- 二頭(右) -->
                                        <g class="muscle-pair" data-muscle="bicepsRight" role="button" tabIndex="0">
                                            <g transform="translate(236.24, 162.16) scale(1)">
                                                <path d="M7 1.27494C7 2.03794 5.425 4.95193 3.5 7.75093L0 12.8389V18.6539C0 36.2629 11.495 56.7119 26.214 65.2889C32.343 68.8609 34.983 68.4459 37.381 63.5369L39.261 59.6859L39.77 46.3369C40.345 31.2839 39.179 23.1489 35.372 15.6349C32.623 10.2109 29.054 7.63793 21.03 5.29793C18.022 4.42093 13.877 2.84493 11.82 1.79493C7.35401 -0.483075 7 -0.521064 7 1.27494Z" />
                                            </g>
                                        </g>
                                        <!-- 前臂-->
                                        <g class="muscle-pair" data-muscle="frontForearm" role="button" tabIndex="0">
                                            <!-- 左 -->
                                            <g transform="translate(32.5, 216) scale(0.86)">
                                                <path d="M10.3904 49.48C13.6544 27.498 17.7754 17.168 28.2714 4.65701C30.4204 2.09601 32.5494 0 33.0024 0C33.4554 0 34.0804 1.238 34.3904 2.75C35.7594 9.415 37.0154 12.965 38.7754 15.139L40.6644 17.471L44.7054 17.365C49.3654 17.243 55.1984 14.111 62.1144 8.01599C64.7264 5.71399 66.8644 3.98101 66.8634 4.16501C66.8634 4.34901 66.0164 6.75 64.9804 9.5C63.9454 12.25 62.5734 17.875 61.9334 22C58.7014 42.82 55.3784 51.404 44.9534 65.866C34.9104 79.798 30.2214 87.023 27.4244 92.875C25.8144 96.244 24.1034 99 23.6214 99C23.1404 99 21.0494 97.636 18.9744 95.968C14.7864 92.603 6.19339 89 2.35339 89C-0.654608 89 -0.731599 88.088 1.8504 83.028C4.5244 77.786 8.51441 62.111 10.3904 49.48Z">
                                                </path>
                                            </g>
