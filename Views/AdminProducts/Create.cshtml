@* 填一個 Product商品物件 *@
@model katachi.Models.Shop.Product
@using katachi.Models.Shop

@{
    Layout = null;
    // 接收Controller傳進來的分類資料
    var categories = ViewBag.Categories as List<Category>;
}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <title>新增商品</title>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-page">
    <main class="admin-shell">
        <div class="admin-header">
            <h1 class="admin-title">新增商品</h1>
            <a class="admin-link" asp-action="Index">返回列表</a>
        </div>

        <form class="admin-form" method="post" asp-action="Create">
        <div asp-validation-summary="All" class="admin-alert"></div>

        <div class="admin-field">
            <label>商品代碼</label>
            <input asp-for="ProductCode" />
        </div>

        <div class="admin-field">
            <label>商品名稱</label>
            <input asp-for="Name" />
        </div>

        <div class="admin-field">
            <label>分類</label>
            <select asp-for="CategoryId">
                @foreach (var category in categories ?? new List<Category>())
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>

        <div class="admin-field">
            <label>副標題</label>
            <input asp-for="Subtitle" />
        </div>

        <div class="admin-field">
            <label>描述</label>
            <textarea asp-for="Description"></textarea>
        </div>

        <div class="admin-field">
            <label>價格</label>
            <input asp-for="Price" type="number" />
        </div>

        <div class="admin-field">
            <label>庫存</label>
            <input asp-for="Stock" type="number" min="0" />
        </div>

        <div class="admin-field">
            <label>原價</label>
            <input asp-for="OriginalPrice" type="number" />
        </div>

        <div class="admin-field">
            <label>評分</label>
            <input asp-for="Rating" type="number" step="0.1" />
        </div>

        <div class="admin-field">
            <label>
                <input asp-for="IsActive" />
                上架
            </label>
        </div>

        <div class="admin-actions">
            <button class="admin-btn primary" type="submit">儲存</button>
            <a class="admin-link" asp-action="Index">返回列表</a>
        </div>
        </form>
    </main>
</body>
</html>


