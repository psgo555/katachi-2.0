<!DOCTYPE html>
<html lang="zh-TW">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewBag.Title — KATACHI</title>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;800&family=Cormorant+Garamond:ital,wght@0,300;1,200;1,300&family=Noto+Sans+JP:wght@100;200;300&family=Noto+Serif+JP:wght@200;300;400&display=swap"
          rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
	<script src="~/js/layout.js" defer></script>
    @await RenderSectionAsync("styles", required: false)
</head>
<body>

	<!-- ══════ BYOBU ══════ -->
	<div id="byobu">
		<div id="byobu-left"></div>
		<div id="byobu-right"></div>
	</div>

	<!-- ══════ MENU ══════ -->
    <div id="menu-content">
        <div class="mc-left">
            <ul class="mc-links">
                <li class="mc-item">
                    <a class="mc-link" asp-controller="MuscleMap" asp-action="Index" onclick="closeMenu()">
                        <span class="mc-num">01</span>
                        <span class="mc-text-wrap"><span class="mc-text">肌肉百科</span></span>
                        <span class="mc-en">Muscle Wiki</span>
                    </a>
                </li>
                <li class="mc-item">
                    <a class="mc-link" asp-controller="TrainingLog" asp-action="Index" onclick="closeMenu()">
                        <span class="mc-num">02</span>
                        <span class="mc-text-wrap"><span class="mc-text">訓練日誌</span></span>
                        <span class="mc-en">Exercises</span>
                    </a>
                </li>
                <li class="mc-item">
                    <a class="mc-link" asp-controller="Plan" asp-action="Index" onclick="closeMenu()">
                        <span class="mc-num">03</span>
                        <span class="mc-text-wrap"><span class="mc-text">訓練計畫</span></span>
                        <span class="mc-en">Programs</span>
                    </a>
                </li>
                <li class="mc-item">
                    <a class="mc-link" asp-controller="Nutrition" asp-action="Index" onclick="closeMenu()">
                        <span class="mc-num">04</span>
                        <span class="mc-text-wrap"><span class="mc-text">飲食計算</span></span>
                        <span class="mc-en">Nutrition</span>
                    </a>
                </li>
                <li class="mc-item">
                    <a class="mc-link" asp-controller="Shop" asp-action="Index" onclick="closeMenu()">
                        <span class="mc-num">05</span>
                        <span class="mc-text-wrap"><span class="mc-text">商店 / 會員</span></span>
                        <span class="mc-en">Shop</span>
                    </a>
                </li>
            </ul>
        </div>
        <div class="mc-right">
            <div class="mc-quote">
                精準的訓練，<br>始於對身體<br>的理解
            </div>
        </div>
        <button class="mc-close" onclick="closeMenu()">
            <span class="mc-close-x"></span>
            Close
        </button>
    </div>

	<!-- ══════ NAV ══════ -->
    <nav id="nav">
        <a class="nav-logo" asp-controller="Home" asp-action="Index">
            KATACH<span class="dumbbell-i">
            <svg viewBox="0 0 28 80" fill="none"
                 xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="0" width="24" height="7" rx="1.5" fill="currentColor" />
                <rect x="0" y="9" width="28" height="9" rx="2" fill="currentColor" />
                <rect x="11" y="20" width="6" height="40" fill="currentColor" />
                <rect x="0" y="62" width="28" height="9" rx="2" fill="currentColor" />
                <rect x="2" y="73" width="24" height="7" rx="1.5" fill="currentColor" />
            </svg>
        </span>
    </a>
    <div class="nav-right">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="nav-username">@User.Identity.Name</span>
            <a class="nav-user" asp-controller="Account" asp-action="Logout" title="登出">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="9" cy="6" r="3.25" stroke="currentColor" stroke-width="2" />
                    <path d="M1.5 17c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </a>
        }
        else
        {
            <a class="nav-user" asp-controller="Account" asp-action="Index" title="會員登入">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="9" cy="6" r="3.25" stroke="currentColor" stroke-width="2" />
                    <path d="M1.5 17c0-4.142 3.358-7.5 7.5-7.5s7.5 3.358 7.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
            </a>
        }
        <button id="menu-btn" onclick="openMenu()">
            <span class="menu-lines">
                <span class="menu-line"></span>
                <span class="menu-line"></span>
            </span>
            <span class="menu-btn-text">Menu</span>
        </button>
    </div>
</nav>
    <main>
	<!-- ⭐ 每個頁面的內容放這裡 -->
	@RenderBody()
    </main>
	<!-- ══════ FOOTER ══════ -->
    <footer>
    <div class="footer-top">
        <div class="footer-brand">
            <div class="footer-logo">KATACHI</div>
            <p class="footer-tagline">精準的訓練，始於對身體的理解。每一組動作都應有其意義。</p>
            <div class="footer-social">
                <a href="#" class="footer-social-link">IG</a>
                <a href="#" class="footer-social-link">YT</a>
                <a href="#" class="footer-social-link">FB</a>
            </div>
        </div>
        <div>
            <p class="footer-col-title">功能</p>
            <ul class="footer-links">
                <li><a href="#">肌肉百科</a></li>
                <li><a href="#">動作教學</a></li>
                <li><a href="#">訓練計畫</a></li>
                <li><a href="#">飲食計算</a></li>
            </ul>
        </div>
        <div>
            <p class="footer-col-title">計算工具</p>
            <ul class="footer-links">
                <li><a href="#">1RM 計算器</a></li>
                <li><a href="#">BMI 計算器</a></li>
                <li><a href="#">TDEE 計算器</a></li>
                <li><a href="#">強度百分比表</a></li>
            </ul>
        </div>
        <div>
            <p class="footer-col-title">會員</p>
            <ul class="footer-links">
                <li><a href="#">登入 / 註冊</a></li>
                <li><a href="#">訓練日誌</a></li>
                <li><a href="#">進度追蹤</a></li>
                <li><a href="#">個人儀表板</a></li>
            </ul>
        </div>
    </div>
    <div class="footer-bottom">
        <span class="footer-copy">© 2026 KATACHI. All rights reserved.</span>
        <span class="footer-jp">形 · 重訓訓練百科</span>
        <button class="footer-scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
            <span class="footer-scroll-arr"></span>
            Back to top
        </button>
    </div>  
</footer>

@await RenderSectionAsync("scripts", required: false)
</body>
</html>

