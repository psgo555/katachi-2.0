@model List<katachi.Models.Shop.Order>

@{
    Layout = null;
}

@* 顯示所有訂單 *@
<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <title>訂單管理</title>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-page">
    <main class="admin-shell">
        <div class="admin-header">
            <h1 class="admin-title">訂單管理</h1>
            <a class="admin-link" asp-controller="AdminProducts" asp-action="Index">返回商品管理</a>
        </div>

        <div class="admin-panel">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>訂單編號</th>
                        <th>收件人</th>
                        <th>電話</th>
                        <th>Email</th>
                        <th>總金額</th>
                        <th>狀態</th>
                        <th>建立時間</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        var statusClass = order.Status == "已取消" ? "inactive" : "active";

                        <tr>
                            <td>@order.Id</td>
                            <td>@order.OrderNumber</td>
                            <td>@order.RecipientName</td>
                            <td>@order.RecipientPhone</td>
                            <td>@order.RecipientEmail</td>
                            <td class="number">@order.Total</td>
                            <td><span class="status-badge @statusClass">@order.Status</span></td>
                            <td>@order.CreatedAt</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id">查看明細</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>

